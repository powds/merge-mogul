; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MergeMogul"
config/description="Android Game + Utility Hybrid - Merge game with file manager, gallery, app launcher, and hidden vault."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.png"

[autoload]

SaveSystem="*res://scripts/autoload/save_system.gd"
Settings="*res://scripts/autoload/settings.gd"
GameState="*res://scripts/autoload/game_state.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
Audio="*res://scripts/autoload/audio.gd"
AdManager="*res://scripts/autoload/ad_manager.gd"
VaultManager="*res://scripts/autoload/vault_manager.gd"

[rendering]

renderer/rendering_method="mobile"

[android]

package/unique_name="com.game.mergemogul"
package/name="MergeMogul"
package/version/code=1
package/version/name="1.0.0"
package/signed_debug_release=true
package/signed_release_release=false
keystore/debug="user://debug.keystore"
keystore/release=""
keystore/release_user=""
keystore/release_password=""
manifest/uses_gl_compatibility=false
manifest/supports_gles3=true
manifest/supports_gles2=false
manifest/gpu_mode="auto"
manifest/target_sdk_version=34
manifest/min_sdk_version=21
manifest/camera/permission="android.permission.CAMERA"
manifest/microphone/permission="android.permission.RECORD_AUDIO"
export_credentials/custom_keystore_path=""
export_credentials/keystore_alias=""
export_credentials/keystore_alias_password=""

[editor]

export/android/java_sdk_path="/Applications/Android Studio.app/Contents/jbr/Contents/Home"